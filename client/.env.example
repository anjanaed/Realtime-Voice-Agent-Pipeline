# Copy this file to .env.local and fill in your Choreo values.
# .env.local is gitignored (*.local), so your key won't be committed.
#
# Reminder: VITE_* vars are embedded into the built client bundle and are
# visible to anyone who loads the page. Only put a browser-safe key here.

# Full URL of the Choreo-exposed getToken endpoint.
VITE_TOKEN_URL=https://<your-choreo-endpoint>/getToken

# Choreo API key, sent as a request header on every token request.
VITE_TOKEN_API_KEY=<your-choreo-api-key>

# Header name the key is sent under. Choreo's generated API keys use "api-key".
# Change it if your endpoint expects a different scheme (e.g. OAuth2: set this
# to "Authorization" and the value above to "Bearer <access-token>").
VITE_TOKEN_API_KEY_HEADER=api-key
